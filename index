<script>
var cur = 1;
var total = document.querySelectorAll('.survey-page').length;
function show(n) {
  document.querySelectorAll('.survey-page').forEach(function(p){ p.classList.remove('active'); });
  document.getElementById('p' + n).classList.add('active');
  document.getElementById('progress').style.width = (n/total*100) + '%';
  document.getElementById('counter').textContent = 'Page ' + n + ' of ' + total;
  document.getElementById('prev-btn').style.visibility = n === 1 ? 'hidden' : 'visible';
  document.getElementById('next-btn').textContent = n === total ? 'Done' : 'Next >';
  window.scrollTo(0, 0);
}
document.getElementById('next-btn').addEventListener('click', function(){ if(cur < total){ cur++; show(cur); } });
document.getElementById('prev-btn').addEventListener('click', function(){ if(cur > 1){ cur--; show(cur); } });
document.querySelectorAll('.tab-btn').forEach(function(btn){
  btn.addEventListener('click', function(){
    var set = btn.getAttribute('data-set');
    document.querySelectorAll('[data-set="' + set + '"].tab-btn').forEach(function(b){ b.classList.remove('active'); });
    document.querySelectorAll('[data-set="' + set + '"].tab-pane').forEach(function(p){ p.classList.remove('active'); });
    btn.classList.add('active');
    document.getElementById(btn.getAttribute('data-tab')).classList.add('active');
  });
});
show(1);
</script>
